# Trading Routine — environment template.
# Copy to .env and fill in real values for LOCAL runs.
# Cloud routines inject these vars directly — NEVER commit .env, NEVER let a cloud
# routine create .env at runtime.

# Alpaca (paper) — https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_ENDPOINT=https://paper-api.alpaca.markets
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets

# Tavily research — https://app.tavily.com
TAVILY_API_KEY=

# Telegram notifications — talk to @BotFather to create a bot; talk to @userinfobot for your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: virtual equity override (only needed if the paper account can't be reset to $1,000).
# VIRTUAL_EQUITY=1000
